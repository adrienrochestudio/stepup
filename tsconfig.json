{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    /* Migration step: props/params are not yet all typed. Keep every other
       strict check (incl. strictNullChecks) and tighten this per-file later. */
    "noImplicitAny": false,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    /* Incremental migration: existing .js/.jsx files still compile and are
       not type-checked until they are converted to .ts/.tsx. */
    "allowJs": true,
    "checkJs": false
  },
  "include": ["src"]
}
